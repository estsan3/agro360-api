# Copiar a `.env` y ajustar valores. Todas las variables llevan el prefijo AGRO360_.

# Entorno de ejecución: dev | test | prod
AGRO360_ENTORNO=dev

# URL de la base de datos (SQLAlchemy async).
# SQLite (default para desarrollo):
AGRO360_DATABASE_URL=sqlite+aiosqlite:///./data/agro360.db
# PostgreSQL (producción / cuando el sistema escale):
# AGRO360_DATABASE_URL=postgresql+asyncpg://agro360:agro360@db:5432/agro360

# Secreto para firmar los JWT. CAMBIAR en producción (ej: openssl rand -hex 32).
AGRO360_JWT_SECRETO=cambiar-este-secreto-en-produccion

# Minutos de validez del token de acceso.
AGRO360_JWT_EXPIRACION_MINUTOS=480

# Orígenes permitidos para CORS (separados por coma). Default: front Angular local.
AGRO360_CORS_ORIGINS=http://localhost:4200

# Sembrar datos de demo al iniciar si la base está vacía (solo dev).
AGRO360_SEED_AL_INICIAR=true

# Exponer la API como servidor MCP para agentes de IA (requiere: poetry install --with mcp).
AGRO360_MCP_HABILITADO=false
